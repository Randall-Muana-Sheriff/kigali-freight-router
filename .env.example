PORT=5000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=kigali_freight_coop

JWT_SECRET=replace_with_a_strong_secret

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_URL=

# Keep unset in shared/prod environments.
ALLOW_DESTRUCTIVE_BASELINE=0

# Optional: allows simulator nodes to skip JWT auth on the telemetry socket
# when they present this exact value. Leave unset to disable the bypass.
SIMULATOR_SHARED_SECRET=

# Optional: set to enable horizontal scaling (shared rate limiting, shared
# live-fleet/geofence state, a durable telemetry queue, and the Socket.IO
# Redis adapter for running multiple instances). Leave unset for local dev.
REDIS_URL=

# Optional: absolute path to a Firebase service account JSON file. Enables
# push notifications (e.g. "new delivery assigned") to the driver mobile app
# via Firebase Cloud Messaging. Leave unset to disable push sending.
FIREBASE_SERVICE_ACCOUNT_PATH=
